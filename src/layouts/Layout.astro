---
import "../styles/global.css";
import "lenis/dist/lenis.css";

import { ClientRouter } from "astro:transitions";

import Navigation from "../components/global/Navigation.astro";
import Loader from "../components/global/Loader.astro";

const { layout } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>Zauberberg</title>
        <ClientRouter />
    </head>
    <body>
        {layout?.navigation && <Navigation data={layout.navigation} />}
        <slot />
        <Loader />
    </body></html
>

<script>
    import Zauberberg from "../scripts/Zauberberg";

    console.log("layout loaded");
    const app = new Zauberberg();
    console.log("is app initialized : ", app.initialized);
    app.init();
</script>
