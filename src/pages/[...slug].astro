---
import { generateStaticPaths, getPreviewData } from "../cms/dato";
import isPreview from "../utils/isPreview";

import Layout from "../layouts/Layout.astro";
import Page from "../components/global/Page.astro";

export async function getStaticPaths() {
    return await generateStaticPaths();
}

const params = Astro.params;

const props = Astro.props;

let data = props.data;

if (isPreview()) {
    data = await getPreviewData(params);
}
---

<Layout layout={data.layout} template={data.page._modelApiKey}>
    <Page data={data.page} />
</Layout>
