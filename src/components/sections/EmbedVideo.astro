---
const URL_BY_PROVIDER_UID: Record<string, string> = {
    youtube: "https://www.youtube.com/embed/",
    vimeo: "https://player.vimeo.com/video/",
} as const;

const { data } = Astro.props;

const embedBaseUrl = URL_BY_PROVIDER_UID[data.externalVideo?.provider];

let embedUrl;
if (embedBaseUrl) {
    embedUrl = embedBaseUrl + data.externalVideo?.providerUid;
}
---

<div class="relative aspect-video w-full">
    <iframe
        width="100%"
        height="auto"
        style="position:absolute;top:0;left:0;width:100%;height:100%;"
        src={data.wiredriveEmbedSrc ? data.wiredriveEmbedSrc : embedUrl}
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
    ></iframe>
</div>
