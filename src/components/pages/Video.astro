---
import { Icon } from "astro-icon/components";

const { data } = Astro.props;
---

<div id="video" class="relative h-dvh overflow-hidden">
    <div id="video-video" class="absolute inset-0">
        <video
            class="h-full w-full object-cover"
            autoplay
            muted
            loop
            playsinline
            src={data.video.wiredriveUrl}
            poster={data.video.poster.url}
        >
        </video>
        <div class="absolute inset-0 flex items-center justify-center bg-black/40">
            <div id="video-info" class="flex flex-col items-center gap-5 lg:flex-row lg:gap-15">
                <div class="text-nav flex items-center gap-6">
                    {
                        data.directors.map((director: any) => {
                            return <div>{director.name}</div>;
                        })
                    }
                </div>
                <div class="text-nav-kh flex items-center gap-6">
                    <div>{data.name}</div>
                    <div class="italic">{data.client}</div>
                </div>
            </div>
        </div>
    </div>
    <div
        id="video-controls"
        style={{ "--video-progress": 0.89 }}
        class="px-gutter pointer-events-none absolute inset-0 flex items-center justify-center pb-60 lg:pb-0"
    >
        <div class="flex h-full w-full flex-col items-center justify-end lg:h-auto lg:flex-row">
            <div class="text-nav pointer-events-auto flex items-center gap-10">
                <button class="flex shrink-0 items-center gap-5">
                    <Icon name="cross" class="-mt-1 size-12" />
                    Close
                </button>
                <button class="flex shrink-0 items-center gap-5"> ← Prev </button>
                <button class="flex shrink-0 items-center gap-5"> Next → </button>
                <button class="flex shrink-0 items-center gap-5"> Sound </button>
                <button class="flex shrink-0 items-center gap-5"> More ↓ </button>
            </div>
        </div>
        <div class="absolute right-0 bottom-0 left-0 flex flex-col pb-30">
            <div class="translate-x-[calc(100%*var(--video-progress))] pb-17">
                <div
                    id="video-controls-time"
                    class="hidden -translate-x-1/2 text-[1.2rem] font-medium tracking-[0.08em] uppercase tabular-nums lg:inline-block"
                    >00:14</div
                >
            </div>
            <div class="h-2 w-full bg-white/10">
                <div class="size-full origin-left scale-x-(--video-progress) bg-white"></div>
            </div>
        </div>
    </div>
</div>
